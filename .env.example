# ---- Cliente (expuesto al navegador, debe empezar con VITE_) ----
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# La service_role NO va aquí. Las Edge Functions de Supabase
# (supabase/functions/*) reciben SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY
# automáticamente desde el entorno de Supabase; nunca se exponen al cliente.
