# ---- Cliente (expuesto al navegador, debe empezar con VITE_) ----
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# ---- Solo servidor (NO exponer; usado por /api/createUser en Vercel) ----
# La service_role key tiene permisos totales: jamás la pongas en variables VITE_*
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
